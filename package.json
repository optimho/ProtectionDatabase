{
  "name": "protection-device-db",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "init-db": "npx tsx scripts/init-db.ts",
    "seed-admin": "npx tsx scripts/seed-admin.ts",
    "migrate": "npx tsx scripts/migrate-add-parts.ts && npx tsx scripts/migrate-part-enhancements.ts && npx tsx scripts/migrate-ansi-elements.ts && npx tsx scripts/migrate-add-maintenance-period.ts && npx tsx scripts/migrate-add-data-reports.ts"
  },
  "notes": {
    "dev": "Run dev with: bun run dev  (NOT bun --bun — better-sqlite3 requires Node.js mode)",
    "build": "Build with: bun --bun run build",
    "start": "Run prod with: bun --bun run start",
    "init-db": "Run once with: bun run init-db"
  },
  "dependencies": {
    "better-auth": "^1.6.11",
    "better-sqlite3": "^12.10.0",
    "fflate": "^0.8.3",
    "nanoid": "^5.1.11",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.8.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "bun-types": "^1.3.14",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "better-sqlite3",
    "sharp",
    "unrs-resolver"
  ]
}
